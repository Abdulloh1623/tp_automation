# TP Automation — muhit o'zgaruvchilari namunasi.
# Nusxa oling: cp .env.example .env  va qiymatlarni to'ldiring.

# PostgreSQL baza (Docker tp-postgres, port 5433)
DATABASE_URL="postgresql://tp:PAROL@localhost:5433/tp_automation?schema=public"

# Session JWT maxfiy kaliti — KUCHLI tasodifiy qiymat qo'ying.
# Generatsiya: node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
SESSION_SECRET=""

# Telegram bot (Faza 7) — BotFather'dan olingan token (maxfiy)
TELEGRAM_BOT_TOKEN=""
# Kanal IDsi: -100... yoki @kanal_nomi (bo'sh bo'lsa hisobotlar log rejimida)
TELEGRAM_CHANNEL_ID=""
# To'lovlar kanali (chek + mijoz ma'lumoti); bo'sh bo'lsa log rejimi
TELEGRAM_PAYMENTS_CHANNEL_ID=""
# Backup (zaxira) kanali — kunlik DB nusxasi yuboriladi; bo'sh bo'lsa skip
TELEGRAM_BACKUP_CHANNEL_ID=""
# Xato (error) kanali — server/worker xatolari avtomatik yuboriladi.
# Bo'sh bo'lsa backup → asosiy kanalga tushadi; ular ham bo'lmasa faqat konsolga.
TELEGRAM_ERRORS_CHANNEL_ID=""
